# justfile for llama-runner 🦙


# 👨‍💻 Interactive dev session
dev:
    cargo run

# 🛠️ Full release build with bindings (Nightly assumed set)
build:
    REGEN_BINDINGS=1 cargo build --release -vv

# 💬 Run with direct prompt input
run PROMPT:
    cargo run --release -- --prompt '{{PROMPT}}'

# 🔁 Rebuild bindings only
bindings:
    REGEN_BINDINGS=1 cargo build --release

# 🧹 Clean build artifacts
clean:
    cargo clean
    rm -f src/bindings/llama.rs || true

# 🧬 Show Rust and system info
env:
    rustc --version
    cargo --version
    rustup show active-toolchain
    uname -a
