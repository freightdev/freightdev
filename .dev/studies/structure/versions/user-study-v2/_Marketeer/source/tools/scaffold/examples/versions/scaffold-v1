#!/usr/bin/env zsh

# ============================================================================
# ADVANCED FOLDER SCAFFOLD GENERATOR
# ============================================================================
# Configuration Section - Edit these values as needed
# ============================================================================

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly PURPLE='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly WHITE='\033[1;37m'
readonly NC='\033[0m' # No Color

# Script configuration
readonly SCRIPT_NAME="scaffold"
readonly VERSION="1.0.0"
readonly MAX_DEPTH=20
readonly MAX_FILES_PER_DIR=1000

# File patterns to recognize
readonly VALID_EXTENSIONS=("md" "txt" "tree" "scaffold" "struct")
readonly COMMENT_PATTERNS=("#" "//" "<!--" "/*")
readonly EMOJI_PATTERN='[🤖🧠📚📝🦙💾📁📄⚙️🔧🎯🚀💡🔍⭐🎨🛠️📊🎭🔒🌟💻🎪]'

# Suspicious patterns that warrant user confirmation
readonly SUSPICIOUS_PATTERNS=(
    '\$\{[^}]*\}'           # Variable substitution
    '`[^`]*`'               # Command substitution
    '\$\([^)]*\)'           # Command substitution
    '[;&|<>]'               # Shell operators
    '\.\./+'                # Directory traversal
    '^/+'                   # Absolute paths
    '[*?{}[\]]'             # Glob patterns
    '[^a-zA-Z0-9._/-]+'     # Special characters
    '\s+\|\s+'              # Pipe operators
)

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

print_banner() {
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${WHITE}            ADVANCED FOLDER SCAFFOLD GENERATOR v${VERSION}           ${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo
}

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_debug() {
    [[ -n "$DEBUG" ]] && echo -e "${PURPLE}[DEBUG]${NC} $1"
}

show_usage() {
    echo -e "${WHITE}Usage:${NC}"
    echo -e "  $SCRIPT_NAME <input_file> <output_path> [options]"
    echo
    echo -e "${WHITE}Options:${NC}"
    echo -e "  --dry, --preview    Show what would be created without actually creating"
    echo -e "  --force            Skip confirmation prompts"
    echo -e "  --debug            Enable debug output"
    echo -e "  --max-depth N      Maximum directory depth (default: $MAX_DEPTH)"
    echo -e "  --help, -h         Show this help message"
    echo
    echo -e "${WHITE}Supported file types:${NC} ${VALID_EXTENSIONS[*]}"
    echo
    echo -e "${WHITE}Examples:${NC}"
    echo -e "  $SCRIPT_NAME structure.md ./project --dry"
    echo -e "  $SCRIPT_NAME folder.tree /tmp/test --force"
    echo -e "  $SCRIPT_NAME complex.txt ./output --max-depth 10"
}

# ============================================================================
# VALIDATION FUNCTIONS
# ============================================================================

validate_input_file() {
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
        log_error "Input file does not exist: $file"
        return 1
    fi
    
    if [[ ! -r "$file" ]]; then
        log_error "Cannot read input file: $file"
        return 1
    fi
    
    local ext="${file##*.}"
    if [[ ! " ${VALID_EXTENSIONS[*]} " =~ " $ext " ]]; then
        log_warning "File extension '$ext' not in recognized types: ${VALID_EXTENSIONS[*]}"
        echo -n "Continue anyway? [y/N]: "
        read -r response
        [[ "$response" =~ ^[Yy]$ ]] || return 1
    fi
    
    return 0
}

validate_output_path() {
    local path="$1"
    
    if [[ -e "$path" && -n "$(ls -A "$path" 2>/dev/null)" ]]; then
        log_warning "Output directory exists and is not empty: $path"
        if [[ "$FORCE" != "true" ]]; then
            echo -n "Continue and potentially overwrite contents? [y/N]: "
            read -r response
            [[ "$response" =~ ^[Yy]$ ]] || return 1
        fi
    fi
    
    # Try to create parent directory
    local parent_dir="$(dirname "$path")"
    if [[ ! -d "$parent_dir" ]]; then
        if ! mkdir -p "$parent_dir" 2>/dev/null; then
            log_error "Cannot create parent directory: $parent_dir"
            return 1
        fi
    fi
    
    return 0
}

detect_suspicious_patterns() {
    local content="$1"
    local file="$2"
    local warnings=()
    
    for pattern in "${SUSPICIOUS_PATTERNS[@]}"; do
        if echo "$content" | grep -qE "$pattern"; then
            local matches=$(echo "$content" | grep -E "$pattern" | head -3)
            warnings+=("Pattern '$pattern' found in: $(echo "$matches" | tr '\n' ' ')")
        fi
    done
    
    if [[ ${#warnings[@]} -gt 0 ]]; then
        log_warning "Suspicious patterns detected in $file:"
        for warning in "${warnings[@]}"; do
            echo -e "  ${YELLOW}⚠️${NC} $warning"
        done
        
        if [[ "$FORCE" != "true" ]]; then
            echo -e "\n${RED}These patterns might indicate:"
            echo -e "  • Command injection attempts"
            echo -e "  • Path traversal attacks"
            echo -e "  • Unintended shell expansion"
            echo -e "  • Malformed directory names${NC}"
            echo
            echo -n "Do you want to continue? [y/N]: "
            read -r response
            [[ "$response" =~ ^[Yy]$ ]] || return 1
        fi
    fi
    
    return 0
}

# ============================================================================
# PARSING FUNCTIONS
# ============================================================================

normalize_line() {
    local line="$1"
    
    # Remove comments
    for comment in "${COMMENT_PATTERNS[@]}"; do
        line=$(echo "$line" | sed "s/$comment.*//g")
    done
    
    # Remove emojis and extra whitespace
    line=$(echo "$line" | sed -E "s/$EMOJI_PATTERN//g" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    
    # Remove tree characters
    line=$(echo "$line" | sed -E 's/^[│├└─┐┌┘┗┓┏┛┗┃━┣┫┳┻╋╭╮╯╰╱╲╳]*[[:space:]]*//')
    
    echo "$line"
}

extract_structure() {
    local file="$1"
    local content
    local -a structure_lines=()
    local line_num=0
    
    log_info "Parsing structure from: $file"
    
    content=$(cat "$file")
    
    # Detect suspicious patterns first
    detect_suspicious_patterns "$content" "$file" || return 1
    
    while IFS= read -r raw_line; do
        ((line_num++))
        local line=$(normalize_line "$raw_line")
        
        # Skip empty lines and pure comments
        [[ -z "$line" ]] && continue
        
        # Calculate indentation level
        local indent_level=0
        local temp_line="$raw_line"
        
        # Count leading whitespace and tree characters
        while [[ "$temp_line" =~ ^[[:space:]│├└─┐┌┘┗┓┏┛┗┃━┣┫┳┻╋╭╮╯╰╱╲╳] ]]; do
            if [[ "$temp_line" =~ ^[[:space:]] ]]; then
                ((indent_level++))
            elif [[ "$temp_line" =~ ^[│├└─] ]]; then
                ((indent_level += 2))
            else
                ((indent_level++))
            fi
            temp_line="${temp_line:1}"
        done
        
        # Normalize indent level to directory depth
        local depth=$((indent_level / 4))
        [[ $depth -gt $MAX_DEPTH ]] && depth=$MAX_DEPTH
        
        # Determine if it's a file or directory
        local is_file=false
        if [[ "$line" =~ \.[a-zA-Z0-9]+$ && ! "$line" =~ /$ ]]; then
            is_file=true
        fi
        
        structure_lines+=("$depth:$is_file:$line:$line_num")
        log_debug "Parsed line $line_num: depth=$depth, is_file=$is_file, content='$line'"
    done < "$file"
    
    log_success "Parsed ${#structure_lines[@]} structure entries"
    
    # Output structure for processing
    printf '%s\n' "${structure_lines[@]}"
}

# ============================================================================
# CREATION FUNCTIONS
# ============================================================================

create_structure() {
    local output_path="$1"
    local -a structure=("${(@f)$(cat)}")  # Read structure from stdin
    local -a created_dirs=()
    local -a created_files=()
    local -a failed_items=()
    
    log_info "Creating structure at: $output_path"
    
    # Create base output directory
    if [[ "$DRY_RUN" != "true" ]]; then
        mkdir -p "$output_path" || {
            log_error "Failed to create base directory: $output_path"
            return 1
        }
    fi
    
    for entry in "${structure[@]}"; do
        local depth="${entry%%:*}"
        local rest="${entry#*:}"
        local is_file="${rest%%:*}"
        local rest2="${rest#*:}"
        local item_name="${rest2%%:*}"
        local line_num="${rest2#*:}"
        
        # Skip invalid entries
        [[ -z "$item_name" || "$item_name" == "." || "$item_name" == ".." ]] && continue
        
        # Build full path
        local full_path="$output_path/$item_name"
        
        # Sanitize path
        full_path=$(echo "$full_path" | sed 's|//*/|/|g')  # Remove duplicate slashes
        
        if [[ "$is_file" == "true" ]]; then
            # Create file
            local dir_path="$(dirname "$full_path")"
            
            if [[ "$DRY_RUN" == "true" ]]; then
                echo -e "${CYAN}[DRY]${NC} Would create file: $full_path"
            else
                mkdir -p "$dir_path" 2>/dev/null
                if touch "$full_path" 2>/dev/null; then
                    created_files+=("$full_path")
                    log_debug "Created file: $full_path"
                else
                    failed_items+=("FILE:$full_path:$line_num")
                    log_warning "Failed to create file: $full_path (line $line_num)"
                fi
            fi
        else
            # Create directory
            if [[ "$DRY_RUN" == "true" ]]; then
                echo -e "${CYAN}[DRY]${NC} Would create directory: $full_path"
            else
                if mkdir -p "$full_path" 2>/dev/null; then
                    created_dirs+=("$full_path")
                    log_debug "Created directory: $full_path"
                else
                    failed_items+=("DIR:$full_path:$line_num")
                    log_warning "Failed to create directory: $full_path (line $line_num)"
                fi
            fi
        fi
    done
    
    # Print summary
    echo
    log_success "Structure creation complete!"
    echo -e "${WHITE}Summary:${NC}"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        echo -e "  ${BLUE}Mode:${NC} Dry run (no files created)"
    else
        echo -e "  ${GREEN}Directories created:${NC} ${#created_dirs[@]}"
        echo -e "  ${GREEN}Files created:${NC} ${#created_files[@]}"
    fi
    
    if [[ ${#failed_items[@]} -gt 0 ]]; then
        echo -e "  ${RED}Failed items:${NC} ${#failed_items[@]}"
        for item in "${failed_items[@]}"; do
            local type="${item%%:*}"
            local path="${item#*:}"
            local line="${path##*:}"
            local clean_path="${path%:*}"
            echo -e "    ${RED}✗${NC} $type: $clean_path (line $line)"
        done
    fi
    
    return 0
}

# ============================================================================
# MAIN EXECUTION
# ============================================================================

main() {
    local input_file=""
    local output_path=""
    local DRY_RUN=false
    local FORCE=false
    local DEBUG=false
    local MAX_DEPTH=20
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry|--preview)
                DRY_RUN=true
                shift
                ;;
            --force)
                FORCE=true
                shift
                ;;
            --debug)
                DEBUG=true
                shift
                ;;
            --max-depth)
                MAX_DEPTH="$2"
                shift 2
                ;;
            --help|-h)
                show_usage
                exit 0
                ;;
            -*)
                log_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
            *)
                if [[ -z "$input_file" ]]; then
                    input_file="$1"
                elif [[ -z "$output_path" ]]; then
                    output_path="$1"
                else
                    log_error "Too many arguments"
                    show_usage
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Show banner
    print_banner
    
    # Validate required arguments
    if [[ -z "$input_file" || -z "$output_path" ]]; then
        log_error "Both input file and output path are required"
        show_usage
        exit 1
    fi
    
    # Validate inputs
    validate_input_file "$input_file" || exit 1
    validate_output_path "$output_path" || exit 1
    
    # Export variables for use in functions
    export DRY_RUN FORCE DEBUG MAX_DEPTH
    
    # Process the file
    log_info "Starting scaffold generation..."
    
    if extract_structure "$input_file" | create_structure "$output_path"; then
        echo
        log_success "Scaffold generation completed successfully!"
        
        if [[ "$DRY_RUN" != "true" ]]; then
            echo -e "\n${WHITE}Generated structure:${NC}"
            tree "$output_path" 2>/dev/null || ls -la "$output_path"
        fi
    else
        log_error "Scaffold generation failed"
        exit 1
    fi
}

# Run main function with all arguments
main "$@"