#!/usr/bin/env zsh

# Simple working scaffold script
# No dependencies required

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

DRY_RUN=false
DEBUG=false

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_debug() { [[ "$DEBUG" == "true" ]] && echo -e "${CYAN}[DEBUG]${NC} $1"; }

show_usage() {
    echo "Usage: $0 <input_file> <output_path> [--dry] [--debug]"
    echo "Example: $0 structure.tree ./output --dry"
}

# Simple function to extract clean directory/file name
extract_name() {
    local line="$1"
    # Remove tree chars, emojis, comments - keep it simple
    echo "$line" | sed -E 's/^[[:space:]]*[│├└─┐┌┘┗┓┏┛┗┃━┣┫┳┻╋╭╮╯╰╱╲╳]*[[:space:]]*//' | \
                  sed 's/#.*$//' | \
                  sed 's/[🤖🧠📚📝🦙💾📁📄⚙️🔧🎯🚀💡🔍⭐🎨🛠️📊🎭🔒🌟💻🎪]//g' | \
                  sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | \
                  sed 's|/$||'
}

# Get indentation depth
get_depth() {
    local line="$1"
    local depth=0
    local i=0
    
    while [[ $i -lt ${#line} ]]; do
        case "${line:$i:1}" in
            ' ') ((depth++)) ;;
            $'\t') ((depth += 4)) ;;
            '│'|'├'|'└'|'─') ((depth += 2)) ;;
            *) break ;;
        esac
        ((i++))
    done
    
    echo $((depth / 4))
}

main() {
    local input_file=""
    local output_path=""
    
    # Parse args
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry|--preview) DRY_RUN=true; shift ;;
            --debug) DEBUG=true; shift ;;
            --help|-h) show_usage; exit 0 ;;
            -*) log_error "Unknown option: $1"; exit 1 ;;
            *)
                if [[ -z "$input_file" ]]; then
                    input_file="$1"
                elif [[ -z "$output_path" ]]; then
                    output_path="$1"
                fi
                shift
                ;;
        esac
    done
    
    # Validate
    [[ -z "$input_file" || -z "$output_path" ]] && { show_usage; exit 1; }
    [[ ! -f "$input_file" ]] && { log_error "File not found: $input_file"; exit 1; }
    
    log_info "Processing: $input_file -> $output_path"
    
    # Create base dir
    [[ "$DRY_RUN" != "true" ]] && mkdir -p "$output_path"
    
    # Track current path parts
    local -a path_parts=()
    local created_dirs=0
    local created_files=0
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines
        [[ -z "$(echo "$line" | tr -d '[:space:]')" ]] && continue
        
        local name=$(extract_name "$line")
        [[ -z "$name" ]] && continue
        
        local depth=$(get_depth "$line")
        log_debug "Line: '$name' depth: $depth"
        
        # Adjust path_parts array to current depth
        while [[ ${#path_parts[@]} -gt $depth ]]; do
            unset 'path_parts[-1]'
        done
        
        # Build full path
        local full_path="$output_path"
        for part in "${path_parts[@]}"; do
            full_path="$full_path/$part"
        done
        full_path="$full_path/$name"
        
        # Check if it's a file (has extension)
        if [[ "$name" =~ \.[a-zA-Z0-9]+$ ]]; then
            # It's a file
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "FILE: $full_path"
            else
                touch "$full_path" 2>/dev/null && ((created_files++))
            fi
        else
            # It's a directory
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "DIR:  $full_path/"
            else
                mkdir -p "$full_path" 2>/dev/null && ((created_dirs++))
            fi
            # Add to path for nested items
            path_parts+=("$name")
        fi
        
    done < "$input_file"
    
    echo
    log_success "Done!"
    if [[ "$DRY_RUN" != "true" ]]; then
        echo "Created: $created_dirs directories, $created_files files"
        if command -v tree >/dev/null 2>&1; then
            tree "$output_path"
        fi
    fi
}

main "$@"