#!/usr/bin/env bash

# Robust Directory Scaffold Script
# Supports multiple formats, security checks, Unicode, and flexible parsing
# Usage: ./scaffold <input_file> <output_path> [options]

set -euo pipefail  # Strict mode

# Color constants
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly MAGENTA='\033[0;35m'
readonly NC='\033[0m'

# Default options
DRY_RUN=false
DEBUG=false
FORCE=false
MAX_DEPTH=50

# Logging functions
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_debug() { [[ "$DEBUG" == "true" ]] && echo -e "${CYAN}[DEBUG]${NC} $1"; }
log_security() { echo -e "${MAGENTA}[SECURITY]${NC} $1"; }

show_usage() {
    cat << 'EOF'
Usage: ./scaffold <input_file> <output_path> [options]

OPTIONS:
  --dry, --preview      Show what would be created without making changes
  --debug              Enable detailed debug output  
  --force              Skip security warnings and confirmations
  --max-depth N        Limit directory nesting depth (default: 50)
  --help, -h           Show this help

EXAMPLES:
  ./scaffold structure.tree ./output --dry
  ./scaffold enterprise.md ./app --force
  ./scaffold mixed.txt ./test --debug --max-depth 10

SUPPORTED FORMATS:
  - Tree files (.tree, .txt): ASCII/Unicode tree structures
  - Markdown (.md): Code blocks with directory structures  
  - Mixed formats with comments (#, //, <!-- -->)

SECURITY FEATURES:
  - Detects suspicious patterns (command injection, path traversal)
  - Validates file paths and names
  - Limits nesting depth to prevent issues
  - Sanitizes Unicode and special characters
EOF
}

# Security pattern detection
detect_suspicious_patterns() {
    local file="$1"
    local warnings=()
    
    # Check for command injection patterns
    if grep -q '\$(' "$file" 2>/dev/null || grep -q '`' "$file" 2>/dev/null; then
        warnings+=("Command injection patterns detected (\$(...) or backticks)")
    fi
    
    # Check for path traversal
    if grep -q '\.\.\/' "$file" 2>/dev/null || grep -q '\.\.\\' "$file" 2>/dev/null; then
        warnings+=("Path traversal patterns detected (../)")
    fi
    
    # Check for suspicious extensions
    if grep -qE '\.(sh|exe|bat|cmd|ps1|scr)$' "$file" 2>/dev/null; then
        warnings+=("Executable file extensions detected")
    fi
    
    # Check for very deep nesting
    local max_line_spaces=$(grep -E '^[[:space:]]*' "$file" | sed 's/[^[:space:]].*$//' | wc -L)
    if [[ $max_line_spaces -gt 200 ]]; then
        warnings+=("Extremely deep nesting detected (${max_line_spaces} spaces)")
    fi
    
    # Check for very long paths
    if grep -qE '.{200,}' "$file" 2>/dev/null; then
        warnings+=("Very long file/directory names detected")
    fi
    
    if [[ ${#warnings[@]} -gt 0 ]]; then
        log_security "Suspicious patterns detected in $file:"
        for warning in "${warnings[@]}"; do
            log_security "  - $warning"
        done
        
        if [[ "$FORCE" != "true" ]]; then
            echo
            read -p "Continue anyway? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                log_error "Aborted due to security concerns"
                exit 1
            fi
        else
            log_warning "Security warnings ignored due to --force flag"
        fi
    fi
}

# Enhanced name extraction with Unicode support
extract_name() {
    local line="$1"
    local cleaned="$line"
    
    # Remove leading whitespace
    cleaned=$(echo "$cleaned" | sed 's/^[[:space:]]*//')
    
    # Remove tree characters (support various styles)
    cleaned=$(echo "$cleaned" | sed -E 's/^[├└│┌┐┘┗┓┏┣┫┳┻╋┼─═║╠╣╦╩╬┆┊┈┉▪▫■□▲▼◆◇○●★☆♦♠♥♣]+[[:space:]]*//')
    
    # Remove markdown list markers
    cleaned=$(echo "$cleaned" | sed -E 's/^[-*+][[:space:]]*//')
    
    # Remove comments (multiple styles)
    cleaned=$(echo "$cleaned" | sed 's/[[:space:]]*#.*$//')           # Shell/Python style
    cleaned=$(echo "$cleaned" | sed 's/[[:space:]]*\/\/.*$//')        # C++ style  
    cleaned=$(echo "$cleaned" | sed 's/[[:space:]]*<!--.*-->.*$//')   # HTML style
    
    # Clean up whitespace and trailing slashes
    cleaned=$(echo "$cleaned" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed 's|/*$||')
    
    # Sanitize for filesystem safety (but preserve Unicode)
    cleaned=$(echo "$cleaned" | tr -d '\0' | sed 's/[<>:"|?*]/_/g')
    
    echo "$cleaned"
}

# Enhanced depth calculation 
get_depth() {
    local line="$1"
    local depth=0
    local i=0
    
    # Count leading whitespace and tree characters
    while [[ $i -lt ${#line} ]]; do
        case "${line:$i:1}" in
            ' ') ((depth++)) ;;
            $'\t') ((depth += 4)) ;;
            '│'|'┆'|'┊'|'║') ((depth += 4)) ;;  # Vertical continuation chars
            '├'|'└'|'┌'|'┐'|'┘'|'┗'|'┓'|'┏') ((depth += 4)) ;;  # Branch chars
            '─'|'═'|'┈'|'┉') ;;  # Horizontal chars - don't add depth
            *) break ;;
        esac
        ((i++))
    done
    
    local calculated_depth=$((depth / 4))
    
    # Apply max depth limit
    if [[ $calculated_depth -gt $MAX_DEPTH ]]; then
        log_warning "Line exceeds max depth ($MAX_DEPTH): truncating"
        calculated_depth=$MAX_DEPTH
    fi
    
    log_debug "Depth calculation: '$line' -> $depth chars -> depth $calculated_depth"
    echo $calculated_depth
}

# Enhanced file detection
is_file() {
    local name="$1"
    
    # Has file extension
    if [[ "$name" =~ \.[a-zA-Z0-9]{1,10}$ ]]; then
        return 0
    fi
    
    # Common patterns that indicate files
    if [[ "$name" =~ (README|LICENSE|CHANGELOG|Makefile|Dockerfile)$ ]]; then
        return 0
    fi
    
    # Ends with / indicates directory
    if [[ "$name" =~ /$ ]]; then
        return 1
    fi
    
    return 1
}

# Sanitize and validate paths
sanitize_path() {
    local path="$1"
    
    # Remove duplicate slashes
    path=$(echo "$path" | sed 's|/\+|/|g')
    
    # Remove trailing slash (except for root)
    path=$(echo "$path" | sed 's|/$||')
    
    # Validate path length
    if [[ ${#path} -gt 260 ]]; then
        log_warning "Path too long (${#path} chars), truncating: ${path:0:50}..."
        return 1
    fi
    
    echo "$path"
}

# Main processing function
main() {
    local input_file=""
    local output_path=""
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry|--preview) DRY_RUN=true; shift ;;
            --debug) DEBUG=true; shift ;;
            --force) FORCE=true; shift ;;
            --max-depth) MAX_DEPTH="$2"; shift 2 ;;
            --help|-h) show_usage; exit 0 ;;
            -*) log_error "Unknown option: $1"; show_usage; exit 1 ;;
            *)
                if [[ -z "$input_file" ]]; then
                    input_file="$1"
                elif [[ -z "$output_path" ]]; then
                    output_path="$1"
                else
                    log_error "Too many arguments"
                    show_usage
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate arguments
    if [[ -z "$input_file" || -z "$output_path" ]]; then
        log_error "Missing required arguments"
        show_usage
        exit 1
    fi
    
    if [[ ! -f "$input_file" ]]; then
        log_error "Input file not found: $input_file"
        exit 1
    fi
    
    # Security checks
    log_info "Running security checks on $input_file..."
    detect_suspicious_patterns "$input_file"
    
    # Initialize processing
    local start_time=$(date +%s)
    log_info "Processing: $input_file -> $output_path (max depth: $MAX_DEPTH)"
    
    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "DRY RUN MODE - No files will be created"
    else
        output_path=$(sanitize_path "$output_path")
        mkdir -p "$output_path"
        log_info "Created base directory: $output_path"
    fi
    
    # Processing state
    local -a dir_stack=()
    local created_dirs=0
    local created_files=0
    local skipped_items=0
    local line_num=0
    local total_lines=$(wc -l < "$input_file")
    
    log_info "Processing $total_lines lines..."
    
    # Main processing loop
    while IFS= read -r line || [[ -n "$line" ]]; do
        ((line_num++))
        
        # Progress indicator for large files
        if [[ $total_lines -gt 100 ]] && [[ $((line_num % 50)) -eq 0 ]]; then
            local progress=$((line_num * 100 / total_lines))
            echo "Progress: $progress% ($line_num/$total_lines lines)"
        fi
        
        # Skip empty lines and pure tree structure lines
        local trimmed=$(echo "$line" | sed 's/^[[:space:]│├└─┌┐┘┗┓┏┣┫┳┻╋═║╠╣╦╩╬┆┊┈┉]*[[:space:]]*$//')
        if [[ -z "$trimmed" ]]; then
            log_debug "Line $line_num: Skipping empty/structure-only line"
            continue
        fi
        
        # Debug: show what we're processing
        log_debug "Line $line_num: Raw='$line'"
        log_debug "Line $line_num: Trimmed='$trimmed'"
        
        # Skip obvious headers/titles (first few lines without tree chars or extensions)
        if [[ $line_num -le 3 ]] && [[ ! "$line" =~ [│├└─/\\\.] ]]; then
            log_debug "Line $line_num: Skipping header/title: '$line'"
            continue
        fi
        
        # Extract name and validate
        local name=$(extract_name "$line")
        if [[ -z "$name" ]] || [[ "$name" =~ ^[[:space:]]*$ ]]; then
            log_debug "Line $line_num: No valid name extracted from '$line'"
            ((skipped_items++))
            continue
        fi
        
        # Calculate depth
        local depth=$(get_depth "$line")
        log_debug "Line $line_num: name='$name', depth=$depth"
        
        # Adjust directory stack to current depth
        while [[ ${#dir_stack[@]} -gt $depth ]]; do
            unset 'dir_stack[-1]'
            log_debug "Popped from stack, new length: ${#dir_stack[@]}"
        done
        
        # Build full path
        local full_path="$output_path"
        for dir in "${dir_stack[@]}"; do
            full_path="$full_path/$dir"
        done
        full_path="$full_path/$name"
        
        # Sanitize the full path
        if ! full_path=$(sanitize_path "$full_path"); then
            log_error "Path too long, skipping: $name"
            ((skipped_items++))
            continue
        fi
        
        # Create file or directory
        if is_file "$name"; then
            # Create file
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "FILE: $full_path"
            else
                local parent_dir=$(dirname "$full_path")
                if mkdir -p "$parent_dir" 2>/dev/null && touch "$full_path" 2>/dev/null; then
                    ((created_files++))
                    log_debug "Created file: $full_path"
                else
                    log_error "Failed to create file: $full_path"
                    ((skipped_items++))
                fi
            fi
        else
            # Create directory
            if [[ "$DRY_RUN" == "true" ]]; then
                echo "DIR:  $full_path/"
            else
                if mkdir -p "$full_path" 2>/dev/null; then
                    ((created_dirs++))
                    log_debug "Created directory: $full_path"
                else
                    log_error "Failed to create directory: $full_path"
                    ((skipped_items++))
                    continue
                fi
            fi
            
            # Add to directory stack for nesting
            dir_stack+=("$name")
            log_debug "Added '$name' to stack, length: ${#dir_stack[@]}"
        fi
        
    done < "$input_file"
    
    # Final summary
    local end_time=$(date +%s)
    local elapsed=$((end_time - start_time))
    
    echo
    log_success "Processing completed in ${elapsed}s"
    log_success "Processed: $line_num lines"
    
    if [[ "$DRY_RUN" != "true" ]]; then
        log_success "Created: $created_dirs directories, $created_files files"
        if [[ $skipped_items -gt 0 ]]; then
            log_warning "Skipped: $skipped_items items (see debug output for details)"
        fi
        
        # Show final structure
        if command -v tree >/dev/null 2>&1 && [[ $created_dirs -lt 100 ]]; then
            echo
            log_info "Final structure:"
            tree "$output_path" 2>/dev/null | head -50
        elif [[ $created_dirs -lt 20 ]]; then
            echo
            log_info "Directory contents:"
            find "$output_path" -type d | head -20
        else
            log_info "Structure too large to display (use 'tree $output_path' to view)"
        fi
    else
        if [[ $skipped_items -gt 0 ]]; then
            log_warning "Would skip: $skipped_items items"
        fi
    fi
}

# Trap for cleanup on exit
trap 'log_debug "Script exiting..."' EXIT

# Run main function
main "$@"