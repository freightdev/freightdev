ASTRO_HOST=open-hwy.com            # Public marketing domain
APP_HOST=app.open-hwy.com          # Flutter app domain
API_HOST=api.open-hwy.com          # API domain
DOWNLOADS_HOST=downloads.open-hwy.com  # Download host (proxies to Flutter downloads)

ASTRO_PORT=4173                    # Port Astro service listens on (inside Compose network)
FLUTTER_PORT=5200                  # Port Flutter web server exposes (inside Compose network)
API_PORT=3000                      # Axum API port
