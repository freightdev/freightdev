FLUTTER_API_BASE_URL=http://localhost:3000/api  # API endpoint used by the Flutter app (auth, loads, payments, etc.)
FLUTTER_AUTH_DOMAIN=http://localhost:3000        # Optional base domain for shared auth links
FLUTTER_DOWNLOAD_URL=http://localhost:8080/downloads  # Where the app can download installers/assets
FLUTTER_STRIPE_SUCCESS_URL=https://app.open-hwy.com/payments/success  # Stripe redirect after payment
FLUTTER_STRIPE_CANCEL_URL=https://app.open-hwy.com/payments/cancel    # Stripe redirect on cancel
FLUTTER_LOG_LEVEL=info  # Debug level for Flutter logging if you wire it into the runtime
