---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    icon: '⚡',
    title: 'Lightning Fast Dispatching',
    description: 'Dispatch loads in seconds with our intuitive interface and smart automation tools.',
  },
  {
    icon: '📱',
    title: 'Mobile-First Design',
    description: 'Manage your operations on the go with our native mobile apps for iOS and Android.',
  },
  {
    icon: '🤖',
    title: 'AI-Powered Assistant',
    description: 'E.L.D.A. learns your workflow and helps automate repetitive tasks.',
  },
  {
    icon: '📊',
    title: 'Real-Time Analytics',
    description: 'Track performance metrics and gain insights with comprehensive reporting tools.',
  },
  {
    icon: '🗺️',
    title: 'Live GPS Tracking',
    description: 'Monitor your fleet in real-time with integrated GPS tracking and geofencing.',
  },
  {
    icon: '💰',
    title: 'Automated Invoicing',
    description: 'Generate and send invoices automatically with integrated payment processing.',
  },
];

const pricingPlans = [
  {
    name: 'Starter',
    price: '$49',
    period: 'per month',
    description: 'Perfect for small carriers getting started',
    features: [
      'Up to 5 trucks',
      'Basic dispatch management',
      'Mobile apps',
      'Email support',
      'Basic reporting',
    ],
    cta: 'Start Free Trial',
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '$149',
    period: 'per month',
    description: 'For growing fleets that need more power',
    features: [
      'Up to 25 trucks',
      'Advanced dispatch & routing',
      'E.L.D.A. AI Assistant',
      'Priority support',
      'Advanced analytics',
      'Document management',
      'Automated invoicing',
    ],
    cta: 'Start Free Trial',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: 'contact us',
    description: 'For large operations with custom needs',
    features: [
      'Unlimited trucks',
      'Custom integrations',
      'Dedicated account manager',
      '24/7 phone support',
      'White-label options',
      'Custom training',
      'API access',
    ],
    cta: 'Contact Sales',
    highlighted: false,
  },
];

const testimonials = [
  {
    quote: 'FED-TMS transformed our dispatch operations. We cut our processing time by 70% and our drivers love the mobile app.',
    author: 'Sarah Johnson',
    role: 'Operations Manager',
    company: 'Swift Logistics',
  },
  {
    quote: 'The AI assistant is incredible. It handles routine tasks so our team can focus on growing the business.',
    author: 'Michael Chen',
    role: 'CEO',
    company: 'Pacific Transport',
  },
  {
    quote: 'Best investment we made. The ROI was clear within the first month. Highly recommend for any carrier.',
    author: 'David Martinez',
    role: 'Fleet Manager',
    company: 'National Freight',
  },
];
---

<BaseLayout title="FED-TMS - Fast & Easy Dispatching">
  <Navbar />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-primary/20 via-background to-purple-secondary/20"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(217,70,239,0.15),transparent_50%)]"></div>

    <div class="relative max-w-7xl mx-auto">
      <div class="text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 bg-gradient-purple bg-clip-text text-transparent">
          Fast & Easy Dispatching
        </h1>
        <p class="text-xl md:text-2xl text-text-secondary mb-8 max-w-3xl mx-auto">
          The modern TMS built for carriers who want to move faster. Dispatch loads, track shipments, and manage your fleet with ease.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href="/signup"
            class="bg-gradient-purple text-white px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-purple-primary/50"
          >
            Start Free Trial
          </a>
          <a
            href="/demo"
            class="bg-background-elevated text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-background-card transition-colors border border-background-elevated"
          >
            Watch Demo
          </a>
        </div>
        <p class="text-text-tertiary text-sm mt-4">No credit card required • 14-day free trial</p>
      </div>

      <!-- Hero Image/Dashboard Preview -->
      <div class="mt-16 relative">
        <div class="absolute inset-0 bg-gradient-purple blur-3xl opacity-20"></div>
        <div class="relative bg-background-card rounded-2xl border border-background-elevated p-4 shadow-2xl">
          <div class="aspect-video bg-background-elevated rounded-lg flex items-center justify-center">
            <div class="text-center">
              <svg class="w-20 h-20 mx-auto mb-4 text-purple-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              <p class="text-text-secondary">Dashboard Preview</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-background-card">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">Everything You Need</h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          Powerful features designed to streamline your transportation operations
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-background-elevated p-8 rounded-xl border border-background-card hover:border-purple-primary/50 transition-colors">
            <div class="text-5xl mb-4">{feature.icon}</div>
            <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
            <p class="text-text-secondary">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">Simple, Transparent Pricing</h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          Choose the plan that fits your fleet size and needs
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {pricingPlans.map((plan) => (
          <div class={`bg-background-card rounded-2xl p-8 border-2 ${plan.highlighted ? 'border-purple-primary shadow-xl shadow-purple-primary/20 scale-105' : 'border-background-elevated'}`}>
            {plan.highlighted && (
              <div class="bg-gradient-purple text-white text-sm font-semibold px-4 py-1 rounded-full inline-block mb-4">
                Most Popular
              </div>
            )}
            <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
            <p class="text-text-secondary mb-6">{plan.description}</p>
            <div class="mb-6">
              <span class="text-4xl font-bold">{plan.price}</span>
              <span class="text-text-secondary ml-2">{plan.period}</span>
            </div>
            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-success mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-text-secondary">{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href="/signup"
              class={`block text-center px-6 py-3 rounded-lg font-semibold transition-all ${
                plan.highlighted
                  ? 'bg-gradient-purple text-white hover:opacity-90'
                  : 'bg-background-elevated text-white hover:bg-background-card border border-background-elevated'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-background-card">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">Trusted by Carriers</h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          See what our customers have to say about FED-TMS
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="bg-background-elevated p-8 rounded-xl">
            <div class="flex mb-4">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="w-5 h-5 text-warning" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-text-secondary mb-6 italic">"{testimonial.quote}"</p>
            <div>
              <p class="font-semibold">{testimonial.author}</p>
              <p class="text-text-tertiary text-sm">{testimonial.role}, {testimonial.company}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-primary/20 to-purple-secondary/20"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to Transform Your Operations?</h2>
      <p class="text-xl text-text-secondary mb-8">
        Join thousands of carriers using FED-TMS to streamline their dispatch operations
      </p>
      <a
        href="/signup"
        class="inline-block bg-gradient-purple text-white px-10 py-4 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-purple-primary/50"
      >
        Start Your Free Trial
      </a>
      <p class="text-text-tertiary text-sm mt-4">No credit card required • Cancel anytime</p>
    </div>
  </section>

  <Footer />
</BaseLayout>
