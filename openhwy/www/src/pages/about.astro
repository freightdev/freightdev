---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const team = [
  { name: 'Leadership', icon: '👔', description: 'Experienced executives from top logistics companies' },
  { name: 'Engineering', icon: '💻', description: 'World-class developers building the future of TMS' },
  { name: 'Support', icon: '🎧', description: 'Dedicated team available 24/7 to help you succeed' },
];

const values = [
  {
    title: 'Customer First',
    description: 'Every decision we make starts with how it benefits our customers.',
    icon: '🎯',
  },
  {
    title: 'Innovation',
    description: 'We continuously push boundaries to deliver cutting-edge solutions.',
    icon: '💡',
  },
  {
    title: 'Reliability',
    description: 'Your business depends on us. We take that responsibility seriously.',
    icon: '⚡',
  },
  {
    title: 'Transparency',
    description: 'Open communication and honest pricing. No hidden fees or surprises.',
    icon: '🔍',
  },
];

const stats = [
  { value: '10,000+', label: 'Active Carriers' },
  { value: '50M+', label: 'Loads Managed' },
  { value: '99.9%', label: 'Uptime SLA' },
  { value: '24/7', label: 'Support Available' },
];
---

<BaseLayout title="About Us - FED-TMS">
  <Navbar />

  <div class="pt-32 pb-20">
    <!-- Hero -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-purple bg-clip-text text-transparent">
          Built by Carriers, for Carriers
        </h1>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          We understand the challenges of running a transportation business because we've been there. FED-TMS was created to solve the real problems carriers face every day.
        </p>
      </div>
    </div>

    <!-- Stats -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl md:text-5xl font-bold bg-gradient-purple bg-clip-text text-transparent mb-2">
              {stat.value}
            </div>
            <div class="text-text-secondary">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Story -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <div class="bg-background-card rounded-2xl p-8 md:p-12 border border-background-elevated">
        <h2 class="text-3xl font-bold mb-6">Our Story</h2>
        <div class="space-y-4 text-text-secondary text-lg">
          <p>
            FED-TMS was born from frustration. As carriers ourselves, we were tired of clunky, outdated software that slowed us down instead of helping us grow. We knew there had to be a better way.
          </p>
          <p>
            In 2020, we set out to build the TMS we wished we had. One that was fast, intuitive, and actually helped us make money. We started with a simple dispatch tool and evolved it based on feedback from real carriers like you.
          </p>
          <p>
            Today, FED-TMS powers over 10,000 carriers across North America. But we're just getting started. Our mission is to give every carrier access to enterprise-grade technology, regardless of their size.
          </p>
        </div>
      </div>
    </div>

    <!-- Values -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-4xl font-bold text-center mb-12">Our Values</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="text-center">
            <div class="text-6xl mb-4">{value.icon}</div>
            <h3 class="text-xl font-semibold mb-2">{value.title}</h3>
            <p class="text-text-secondary">{value.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Team -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-4xl font-bold text-center mb-12">Our Team</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {team.map((dept) => (
          <div class="bg-background-card rounded-xl p-8 border border-background-elevated text-center">
            <div class="text-6xl mb-4">{dept.icon}</div>
            <h3 class="text-2xl font-semibold mb-2">{dept.name}</h3>
            <p class="text-text-secondary">{dept.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-gradient-to-br from-purple-primary/20 to-purple-secondary/20 rounded-2xl p-12 border border-purple-primary/30">
        <h2 class="text-4xl font-bold mb-4">Join Our Mission</h2>
        <p class="text-xl text-text-secondary mb-8">
          We're always looking for talented people who want to make a difference in the transportation industry.
        </p>
        <a
          href="/careers"
          class="inline-block bg-gradient-purple text-white px-10 py-4 rounded-lg text-lg font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-purple-primary/50"
        >
          View Open Positions
        </a>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
