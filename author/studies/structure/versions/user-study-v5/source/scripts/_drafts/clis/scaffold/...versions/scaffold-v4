#!/usr/bin/env zsh

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Configuration
VERSION="1.0.0"
DRY_RUN=false
FORCE=false
DEBUG=false

print_banner() {
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${WHITE}            FOLDER SCAFFOLD GENERATOR v${VERSION}              ${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo
}

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_debug() { [[ "$DEBUG" == "true" ]] && echo -e "${CYAN}[DEBUG]${NC} $1"; }

show_usage() {
    echo "Usage: $0 <input_file> <output_path> [--dry|--preview] [--force] [--debug]"
    echo
    echo "Options:"
    echo "  --dry, --preview    Show what would be created"
    echo "  --force            Skip confirmations"
    echo "  --debug            Enable debug output"
    echo "  --help, -h         Show this help"
    echo
    echo "Example:"
    echo "  $0 structure.tree ./my-project --dry"
}

# Clean a line by removing tree chars, emojis, comments
clean_line() {
    local line="$1"
    
    # Remove comments
    line=$(echo "$line" | sed 's/#.*$//' | sed 's|//.*$||' | sed 's|/\*.*\*/||')
    
    # Remove emojis (basic set)
    line=$(echo "$line" | sed 's/[🤖🧠📚📝🦙💾📁📄⚙️🔧🎯🚀💡🔍⭐🎨🛠️📊🎭🔒🌟💻🎪]//g')
    
    # Remove tree characters and leading/trailing spaces
    line=$(echo "$line" | sed 's/^[[:space:]]*[│├└─┐┌┘┗┓┏┛┗┃━┣┫┳┻╋╭╮╯╰╱╲╳│]*[[:space:]]*//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    
    echo "$line"
}

# Parse structure and build paths properly
parse_and_create() {
    local input_file="$1"
    local output_path="$2"
    local -a dir_stack=()
    local created_dirs=0
    local created_files=0
    local line_num=0
    
    log_info "Processing: $input_file -> $output_path"
    
    # Create base directory
    if [[ "$DRY_RUN" != "true" ]]; then
        mkdir -p "$output_path"
    fi
    
    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        ((line_num++))
        
        # Skip empty lines
        [[ -z "$(echo "$raw_line" | tr -d '[:space:]')" ]] && continue
        
        # Calculate indentation level
        local indent=0
        local temp_line="$raw_line"
        
        # Count leading whitespace and tree characters
        while [[ "$temp_line" =~ ^[[:space:]│├└─┐┌┘┗┓┏┛┗┃━┣┫┳┻╋╭╮╯╰╱╲╳] ]]; do
            if [[ "$temp_line" =~ ^[[:space:]] ]]; then
                ((indent++))
            elif [[ "$temp_line" =~ ^[│├└─] ]]; then
                ((indent += 2))
            else
                ((indent++))
            fi
            temp_line="${temp_line:1}"
        done
        
        # Convert indent to depth level (every 4 chars = 1 level)
        local depth=$((indent / 4))
        
        # Clean the line
        local clean_name=$(clean_line "$raw_line")
        [[ -z "$clean_name" ]] && continue
        
        # Remove trailing slash
        clean_name="${clean_name%/}"
        
        log_debug "Line $line_num: indent=$indent, depth=$depth, name='$clean_name'"
        
        # Adjust directory stack based on depth
        while [[ ${#dir_stack[@]} -gt $depth ]]; do
            unset 'dir_stack[-1]'
        done
        
        # Determine if it's a file (has extension)
        local is_file=false
        if [[ "$clean_name" =~ \.[a-zA-Z0-9]+$ ]]; then
            is_file=true
        fi
        
        # Build full path
        local full_path="$output_path"
        for dir in "${dir_stack[@]}"; do
            full_path="$full_path/$dir"
        done
        full_path="$full_path/$clean_name"
        
        if [[ "$is_file" == "true" ]]; then
            # Create file
            if [[ "$DRY_RUN" == "true" ]]; then
                echo -e "${CYAN}[DRY]${NC} File: $full_path"
            else
                local dir_path="${full_path%/*}"
                mkdir -p "$dir_path" 2>/dev/null
                touch "$full_path" 2>/dev/null && ((created_files++))
            fi
            log_debug "File: $full_path"
        else
            # Create directory and add to stack
            if [[ "$DRY_RUN" == "true" ]]; then
                echo -e "${CYAN}[DRY]${NC} Dir:  $full_path/"
            else
                mkdir -p "$full_path" 2>/dev/null && ((created_dirs++))
            fi
            dir_stack+=("$clean_name")
            log_debug "Dir:  $full_path/ (stack: ${dir_stack[*]})"
        fi
        
    done < "$input_file"
    
    # Summary
    echo
    log_success "Structure creation complete!"
    if [[ "$DRY_RUN" == "true" ]]; then
        echo -e "  ${BLUE}Mode:${NC} Dry run (preview only)"
    else
        echo -e "  ${GREEN}Directories:${NC} $created_dirs"
        echo -e "  ${GREEN}Files:${NC} $created_files"
        echo -e "\n${WHITE}Generated structure:${NC}"
        if command -v tree >/dev/null 2>&1; then
            tree "$output_path"
        else
            find "$output_path" -type d -exec echo "📁 {}" \; 2>/dev/null
            find "$output_path" -type f -exec echo "📄 {}" \; 2>/dev/null
        fi
    fi
}

# Main function
main() {
    local input_file=""
    local output_path=""
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry|--preview) DRY_RUN=true; shift ;;
            --force) FORCE=true; shift ;;
            --debug) DEBUG=true; shift ;;
            --help|-h) show_usage; exit 0 ;;
            -*) log_error "Unknown option: $1"; show_usage; exit 1 ;;
            *)
                if [[ -z "$input_file" ]]; then
                    input_file="$1"
                elif [[ -z "$output_path" ]]; then
                    output_path="$1"
                else
                    log_error "Too many arguments"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    print_banner
    
    # Validate arguments
    if [[ -z "$input_file" || -z "$output_path" ]]; then
        log_error "Both input file and output path required"
        show_usage
        exit 1
    fi
    
    if [[ ! -f "$input_file" ]]; then
        log_error "Input file not found: $input_file"
        exit 1
    fi
    
    if [[ ! -r "$input_file" ]]; then
        log_error "Cannot read input file: $input_file"
        exit 1
    fi
    
    # Check for suspicious patterns
    local suspicious_found=false
    local suspicious_patterns=('\$\{' '`' '\$\(' '[;&|<>]' '\.\.\/' '^/')
    
    for pattern in "${suspicious_patterns[@]}"; do
        if grep -qE "$pattern" "$input_file"; then
            if [[ "$suspicious_found" == "false" ]]; then
                log_warning "Suspicious patterns found in $input_file"
                suspicious_found=true
            fi
            echo -e "  ${YELLOW}⚠️${NC}  Pattern: $pattern"
        fi
    done
    
    if [[ "$suspicious_found" == "true" && "$FORCE" != "true" ]]; then
        echo -e "\n${RED}These patterns could be dangerous. Continue? [y/N]:${NC} "
        read -r response
        [[ ! "$response" =~ ^[Yy]$ ]] && exit 1
    fi
    
    # Process the file
    parse_and_create "$input_file" "$output_path"
}

main "$@"