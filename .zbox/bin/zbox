#!/bin/zsh
#############################
# zBox CLI - Interactive Infrastructure Manager
# The main command-line interface for zBox
#############################

# Ensure zBox is loaded
if [[ -z "$ZBOX_DIR" ]]; then
    source "${HOME}/.zbox/main.zsh"
fi

# zBox CLI version
ZBOX_CLI_VERSION="1.0.0"

#############################
# Help and Usage
#############################
zbox_help() {
    cat <<'EOF'
╔══════════════════════════════════════════════════════════════════════╗
║                         zBox CLI v1.0.0                              ║
║              Interactive Infrastructure Manager                      ║
╚══════════════════════════════════════════════════════════════════════╝

USAGE:
  zbox <command> [options] [arguments]

COMMANDS:
  create             Create new resource (VM, profile, user)
  create -i          Interactive creation wizard

  user               User management
    user create      Create new user
    user login       Login to zBox
    user list        List all users
    user delete      Delete user

  profile            Profile management
    profile list     List profiles
    profile switch   Switch to profile
    profile create   Create new profile

  vm                 Virtual machine management
    vm create        Create VM
    vm list          List VMs
    vm start         Start VM
    vm stop          Stop VM
    vm delete        Delete VM

  node               Node management
    node list        List available nodes
    node add         Add new node
    node status      Check node status

  monitor            Resource monitoring
    monitor start    Start monitoring
    monitor status   Show current status
    monitor profiles Monitor profile sessions

  init               Initialize zBox for first-time use
  status             Show zBox system status
  config             Configuration management
  help               Show this help

FLAGS:
  -i, --interactive  Interactive mode (guided prompts)
  -v, --verbose      Verbose output
  -h, --help         Show help
  --version          Show version

EXAMPLES:
  zbox create -i              Interactive creation wizard
  zbox user create            Create new user interactively
  zbox vm create -i           Create VM with wizard
  zbox profile switch admin   Switch to admin profile
  zbox monitor start          Start resource monitoring
  zbox node list              List available nodes

ENVIRONMENT:
  ZBOX_DIR           zBox installation directory
  ZBOX_USER          Current logged-in user
  ZBOX_PROFILE       Current active profile

For more info: less ~/.zbox/README.md

EOF
}

#############################
# Initialize zBox
#############################
zbox_init_system() {
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "zBox Initialization"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Create required directories
    mkdir -p \
        "$ZBOX_DIR/.env/infra/nodes" \
        "$ZBOX_DIR/.env/profile/users" \
        "$ZBOX_DIR/.env/secret/keys" \
        "$ZBOX_DIR/users" \
        "$ZBOX_DIR/logs/monitoring" \
        "$ZBOX_DIR/logs/sessions"

    echo "✓ Created directory structure"

    # Initialize user system
    if [[ ! -f "$ZBOX_DIR/.env/profile/users/.initialized" ]]; then
        echo ""
        echo "Creating first admin user..."
        zbox_user_create_interactive "admin"
        touch "$ZBOX_DIR/.env/profile/users/.initialized"
    fi

    echo ""
    echo "✓ zBox initialized!"
}

#############################
# Interactive Creation Wizard
#############################
zbox_create_interactive() {
    clear
    cat <<'EOF'
╔══════════════════════════════════════════════════════════════════════╗
║                   zBox Creation Wizard                               ║
╚══════════════════════════════════════════════════════════════════════╝

What would you like to create?

  1) User       - New zBox user account
  2) Profile    - Environment profile
  3) VM         - Virtual machine
  4) Node       - Infrastructure node
  5) Agent      - AI agent environment

  q) Quit

EOF

    read -r "choice?Select option: "

    case "$choice" in
        1) zbox_user_create_interactive ;;
        2) zbox_profile_create_interactive ;;
        3) zbox_vm_create_interactive ;;
        4) zbox_node_create_interactive ;;
        5) zbox_agent_create_interactive ;;
        q|Q) echo "Cancelled"; return 0 ;;
        *) echo "Invalid choice"; zbox_create_interactive ;;
    esac
}

#############################
# User Creation (Interactive)
#############################
zbox_user_create_interactive() {
    local username="${1:-}"

    clear
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Create New zBox User"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Username
    if [[ -z "$username" ]]; then
        read -r "username?Username: "
    fi

    # Validate username
    if [[ -f "$ZBOX_DIR/.env/profile/users/${username}.yaml" ]]; then
        echo "ERROR: User already exists: $username"
        return 1
    fi

    # Full name
    read -r "fullname?Full Name: "

    # Email
    read -r "email?Email: "

    # Phone (optional)
    read -r "phone?Phone (optional): "

    # Password
    echo ""
    read -s -r "password?Password: "
    echo ""
    read -s -r "password2?Confirm Password: "
    echo ""

    if [[ "$password" != "$password2" ]]; then
        echo "ERROR: Passwords do not match"
        return 1
    fi

    # Hash password
    local password_hash=$(echo -n "$password" | sha256sum | awk '{print $1}')

    # Generate SSH key
    echo ""
    echo "Generating SSH keys..."
    local ssh_key_path="$ZBOX_DIR/.env/secret/keys/${username}_ssh"
    ssh-keygen -t ed25519 -f "$ssh_key_path" -N "" -C "${username}@zbox" >/dev/null 2>&1

    # Generate GPG key (non-interactive)
    echo "Generating GPG keys..."
    local gpg_batch="$ZBOX_DIR/.env/secret/keys/${username}_gpg.batch"
    cat > "$gpg_batch" <<EOF
%no-protection
Key-Type: RSA
Key-Length: 4096
Name-Real: $fullname
Name-Email: $email
Expire-Date: 0
EOF

    gpg --batch --gen-key "$gpg_batch" 2>/dev/null
    rm -f "$gpg_batch"

    # Create user profile
    local user_file="$ZBOX_DIR/.env/profile/users/${username}.yaml"
    cat > "$user_file" <<EOF
user:
  username: "$username"
  fullname: "$fullname"
  email: "$email"
  phone: "$phone"
  created: "$(date '+%Y-%m-%d %H:%M:%S')"

auth:
  password_hash: "$password_hash"
  ssh_public_key: "$(cat ${ssh_key_path}.pub)"
  ssh_private_key_path: "$ssh_key_path"
  gpg_key_id: "$(gpg --list-keys "$email" 2>/dev/null | grep -A1 'pub' | tail -1 | tr -d ' ')"

permissions:
  admin: $([ "$username" == "admin" ] && echo "true" || echo "false")
  profiles: []
  nodes: []

settings:
  default_profile: "workspace"
  shell: "/bin/zsh"
EOF

    # Create user directory
    mkdir -p "$ZBOX_DIR/users/$username"

    echo ""
    echo "✓ User created: $username"
    echo "  Email: $email"
    echo "  SSH key: ${ssh_key_path}"
    echo "  GPG key: $(gpg --list-keys "$email" 2>/dev/null | grep -A1 'pub' | tail -1 | tr -d ' ')"
    echo ""
    echo "User can now login with: zbox user login $username"
}

#############################
# User Login
#############################
zbox_user_login() {
    local username="${1:-}"

    if [[ -z "$username" ]]; then
        read -r "username?Username: "
    fi

    local user_file="$ZBOX_DIR/.env/profile/users/${username}.yaml"

    if [[ ! -f "$user_file" ]]; then
        echo "ERROR: User not found: $username"
        return 1
    fi

    # Get password
    read -s -r "password?Password: "
    echo ""

    # Hash and verify
    local password_hash=$(echo -n "$password" | sha256sum | awk '{print $1}')
    local stored_hash=$(grep 'password_hash:' "$user_file" | awk '{print $2}' | tr -d '"')

    if [[ "$password_hash" != "$stored_hash" ]]; then
        echo "ERROR: Invalid password"
        return 1
    fi

    # Create session
    export ZBOX_USER="$username"
    export ZBOX_USER_EMAIL=$(grep 'email:' "$user_file" | awk '{print $2}' | tr -d '"')
    export ZBOX_SESSION_ID="$(date +%s)_$$"

    # Load user's default profile
    local default_profile=$(grep 'default_profile:' "$user_file" | awk '{print $2}' | tr -d '"')

    echo "✓ Logged in as: $username"
    echo "  Profile: $default_profile"

    # Switch to user's profile
    if [[ -n "$default_profile" ]]; then
        zbox_load_manifest "$default_profile" 2>/dev/null
    fi
}

#############################
# Status
#############################
zbox_status() {
    clear
    echo "╔══════════════════════════════════════════════════════════════════════╗"
    echo "║                        zBox System Status                            ║"
    echo "╚══════════════════════════════════════════════════════════════════════╝"
    echo ""

    # System info
    echo "System:"
    echo "  Version:     $ZBOX_CLI_VERSION"
    echo "  Directory:   $ZBOX_DIR"
    echo "  User:        ${ZBOX_USER:-not logged in}"
    echo "  Profile:     ${ZBOX_CURRENT_PROFILE:-none}"
    echo ""

    # Infrastructure
    echo "Infrastructure:"
    zbox_check_infrastructure | grep -E "✅|❌" | sed 's/^/  /'
    echo ""

    # Resources
    echo "Resources:"
    echo "  Profiles:    $(ls -1 $ZBOX_PROFILES 2>/dev/null | wc -l)"
    echo "  VMs:         $(ls -1 $ZBOX_VMS 2>/dev/null | wc -l)"
    echo "  Users:       $(ls -1 $ZBOX_DIR/.env/profile/users/*.yaml 2>/dev/null | wc -l)"
    echo "  Nodes:       $(ls -1 $ZBOX_DIR/.env/infra/nodes/*.yaml 2>/dev/null | wc -l)"
    echo ""

    # Active sessions
    echo "Active Sessions:"
    if [[ -d "$ZBOX_PROFILE_SESSIONS" ]]; then
        # Use (N) glob qualifier to return empty list if no matches
        local session_files=("$ZBOX_PROFILE_SESSIONS"/*.session(N))
        echo "  Profile sessions: ${#session_files[@]}"
    else
        echo "  Profile sessions: 0"
    fi
}

#############################
# Main Command Router
#############################
main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        create)
            if [[ "$1" == "-i" ]] || [[ "$1" == "--interactive" ]]; then
                zbox_create_interactive
            else
                echo "Use: zbox create -i for interactive mode"
            fi
            ;;

        user)
            local subcommand="${1:-help}"
            shift || true
            case "$subcommand" in
                create) zbox_user_create_interactive "$@" ;;
                login)  zbox_user_login "$@" ;;
                list)   ls -1 $ZBOX_DIR/.env/users/*.yaml 2>/dev/null | xargs -n1 basename | sed 's/.yaml//' ;;
                *) echo "Unknown user command: $subcommand" ;;
            esac
            ;;

        profile)
            local subcommand="${1:-list}"
            shift || true
            case "$subcommand" in
                list)   zbox_list_profiles ;;
                switch) zbox_switch_profile "$@" ;;
                info)   zbox_profile_info ;;
                *) echo "Unknown profile command: $subcommand" ;;
            esac
            ;;

        vm)
            local subcommand="${1:-list}"
            shift || true
            case "$subcommand" in
                list)   zbox_vm_list ;;
                create) zbox_vm_create "$@" ;;
                start)  zbox_vm_start "$@" ;;
                stop)   zbox_vm_stop "$@" ;;
                delete) zbox_vm_destroy "$@" ;;
                *) echo "Unknown vm command: $subcommand" ;;
            esac
            ;;

        node)
            local subcommand="${1:-list}"
            shift || true
            case "$subcommand" in
                list)   zbox_node_list ;;
                add)    zbox_node_create_interactive ;;
                status) zbox_node_status "$@" ;;
                *) echo "Unknown node command: $subcommand" ;;
            esac
            ;;

        monitor)
            local subcommand="${1:-status}"
            shift || true
            case "$subcommand" in
                start)    zbox_monitor_start ;;
                status)   zbox_monitor_status ;;
                profiles) zbox_monitor_profiles ;;
                *) echo "Unknown monitor command: $subcommand" ;;
            esac
            ;;

        init)
            zbox_init_system
            ;;

        status)
            zbox_status
            ;;

        help|--help|-h)
            zbox_help
            ;;

        --version|-v)
            echo "zBox CLI v$ZBOX_CLI_VERSION"
            ;;

        *)
            echo "Unknown command: $command"
            echo "Use 'zbox help' for usage"
            return 1
            ;;
    esac
}

# Run if called directly
if [[ "${(%):-%x}" == "$0" ]] || [[ "$0" == *"/zbox" ]]; then
    main "$@"
fi
