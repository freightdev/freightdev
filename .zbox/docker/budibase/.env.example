# Budibase Environment Configuration
# Copy this file to .env and update the values

# Main port for accessing Budibase
MAIN_PORT=10000

# CouchDB Configuration
COUCH_DB_USER=admin
COUCH_DB_PASSWORD=change_me_couchdb_password

# MinIO Configuration (Object Storage)
MINIO_ACCESS_KEY=budibase
MINIO_SECRET_KEY=change_me_minio_password

# Redis Configuration
REDIS_PASSWORD=change_me_redis_password

# Internal API Key (used for service-to-service communication)
INTERNAL_API_KEY=change_me_internal_api_key

# API Encryption Key (used to encrypt sensitive data)
API_ENCRYPTION_KEY=change_me_encryption_key

# JWT Secret (used for token signing)
JWT_SECRET=change_me_jwt_secret

# Budibase Environment
BUDIBASE_ENVIRONMENT=PRODUCTION

# Admin User Configuration (Optional - for initial setup)
BB_ADMIN_USER_EMAIL=admin@example.com
BB_ADMIN_USER_PASSWORD=change_me_admin_password

# Plugins Directory (Optional)
PLUGINS_DIR=/plugins

# Notes:
# - Make sure to change all "change_me_" values to strong, unique passwords
# - For production, use long random strings for security keys
# - You can generate secure random strings with: openssl rand -hex 32
